# =========================================================
# Mada Alinsan - Vercel Environment Variables
# انسخ هذه القيم إلى Vercel Project Settings > Environment Variables
# لا ترفع ملف .env الحقيقي إلى GitHub.
# =========================================================

NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
NEXT_PUBLIC_SITE_NAME=مدى الناس
APP_NAME=مدى الناس
APP_LOCALE=ar
APP_DIRECTION=rtl
APP_TIMEZONE=Asia/Aden

# Database - Supabase PostgreSQL
# ملاحظة: إذا كانت كلمة المرور تحتوي @ فاكتبها %40 داخل الرابط.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:5432/postgres

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=media
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=media

# Admin
ADMIN_EMAIL=mtzallqmy@gmail.com
ADMIN_PASSWORD=
ADMIN_NAME=معتز العلقمي
MOATAZ_ADMIN_PASSWORD=
ADMIN_NOTIFICATION_EMAIL=mtzallqmy@gmail.com
CONTACT_EMAIL=mtzallqmy@gmail.com

# Auth
AUTH_SECRET=CHANGE_TO_LONG_RANDOM_SECRET
NEXTAUTH_SECRET=CHANGE_TO_LONG_RANDOM_SECRET
JWT_SECRET=CHANGE_TO_LONG_RANDOM_SECRET
SESSION_COOKIE_NAME=mada_session

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=
TELEGRAM_ADMIN_IDS=
TELEGRAM_CHANNEL_ID=
TELEGRAM_GROUP_ID=
TELEGRAM_CACHE_CHANNEL_ID=
TELEGRAM_ARTICLES_CHANNEL_ID=
TELEGRAM_WEBHOOK_SECRET=CHANGE_TO_LONG_RANDOM_SECRET

# Email
RESEND_API_KEY=
RESEND_FROM_EMAIL=mtzallqmy@gmail.com
EMAIL_FROM=Mada Alinsan <onboarding@resend.dev>

# Cron / Security
CRON_SECRET=CHANGE_TO_LONG_RANDOM_SECRET

# Feature Flags
ENABLE_NEWSLETTER=true
ENABLE_COMMENTS=true
ENABLE_TELEGRAM_CACHE=true
ENABLE_SEO=true
ENABLE_GEO=true
