generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  OWNER
  ADMIN
  EDITOR
  REVIEWER
  CONTRIBUTOR
  FIELD_REPORTER
  VIEWER
}

enum PostStatus {
  DRAFT
  REVIEW
  NEEDS_EDIT
  SCHEDULED
  PUBLISHED
  ARCHIVED
  REJECTED
}

enum PostType {
  NEWS
  STORY
  HUMAN_MESSAGE
  CASE_FILE
  CONTRIBUTOR_ARTICLE
  REPORT
  PAGE
}

enum CaseStatus {
  SUBMITTED
  UNDER_REVIEW
  VERIFIED
  PUBLISHED
  CONTACTED
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum SubmissionType {
  STORY
  ARTICLE
  CASE_REPORT
  CONTACT
}

enum SubmissionStatus {
  SUBMITTED
  UNDER_REVIEW
  NEEDS_INFO
  APPROVED
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  PDF
  DOCUMENT
  EXTERNAL_LINK
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  role         UserRole      @default(VIEWER)
  avatarUrl    String?
  isActive     Boolean       @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  posts        Post[]        @relation("PostAuthor")
  media        Media[]
  activityLogs ActivityLog[]

  @@index([role])
  @@index([isActive])
}

model Contributor {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  email        String?
  phone        String?
  bio          String?
  avatarUrl    String?
  coverUrl     String?
  facebookUrl  String?
  instagramUrl String?
  xUrl         String?
  whatsappUrl  String?
  telegramUrl  String?
  youtubeUrl   String?
  websiteUrl   String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  posts        Post[]

  @@index([slug])
  @@index([isActive])
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  color       String?
  coverImage  String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  seoTitle    String?
  seoDescription String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts       Post[]

  @@index([slug])
  @@index([isActive, order])
}

model Region {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  city        String?
  country     String   @default("اليمن")
  countryCode String?  @default("YE")
  latitude    Float?
  longitude   Float?
  keywords    String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts       Post[]
  cases       Case[]
  submissions Submission[]

  @@index([slug])
}

model Post {
  id             String     @id @default(cuid())
  title          String
  slug           String     @unique
  excerpt        String?
  content        String
  coverImage     String?
  thumbnail      String?
  quote          String?
  type           PostType   @default(NEWS)
  status         PostStatus @default(DRAFT)
  featured       Boolean    @default(false)
  isStoryOfDay   Boolean    @default(false)
  readingTime    Int        @default(1)
  viewsCount     Int        @default(0)
  publishedAt    DateTime?
  scheduledAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  seoTitle       String?
  seoDescription String?
  seoKeywords    String[]   @default([])
  ogTitle        String?
  ogDescription  String?
  ogImage        String?
  twitterTitle   String?
  twitterDescription String?
  twitterImage   String?
  canonicalUrl   String?

  city           String?
  country        String?    @default("اليمن")
  geoKeywords    String[]   @default([])
  latitude       Float?
  longitude      Float?

  authorId       String?
  author         User?      @relation("PostAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  contributorId  String?
  contributor    Contributor? @relation(fields: [contributorId], references: [id], onDelete: SetNull)
  categoryId     String?
  category       Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  regionId       String?
  region         Region?    @relation(fields: [regionId], references: [id], onDelete: SetNull)

  media          Media[]
  tags           PostTag[]

  @@index([slug])
  @@index([status, publishedAt])
  @@index([status, scheduledAt])
  @@index([type])
  @@index([categoryId])
  @@index([regionId])
}

model Tag {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  posts     PostTag[]
}

model PostTag {
  postId String
  tagId  String
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

model Case {
  id                String     @id @default(cuid())
  title             String
  slug              String     @unique
  type              String
  description        String
  fullDescription    String?
  urgencyLevel       Int        @default(1)
  status            CaseStatus @default(SUBMITTED)
  responsibleEntity  String?
  contactPerson      String?
  coverImage         String?
  lastUpdated        DateTime   @default(now())
  publishedAt        DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  seoTitle           String?
  seoDescription     String?
  geoKeywords        String[]   @default([])
  latitude           Float?
  longitude          Float?

  regionId           String?
  region             Region?    @relation(fields: [regionId], references: [id], onDelete: SetNull)
  updates            CaseUpdate[]
  media              Media[]

  @@index([slug])
  @@index([status])
  @@index([urgencyLevel])
  @@index([regionId])
}

model CaseUpdate {
  id        String     @id @default(cuid())
  caseId    String
  title     String
  body      String
  status    CaseStatus?
  createdAt DateTime   @default(now())
  case      Case       @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model Submission {
  id              String           @id @default(cuid())
  type            SubmissionType
  status          SubmissionStatus @default(SUBMITTED)
  fullName        String?
  email           String?
  phone           String?
  isAnonymous     Boolean          @default(false)
  title           String?
  summary         String?
  body            String
  socialUrl       String?
  allowPublish    Boolean          @default(false)
  allowPhoto       Boolean          @default(false)
  urgencyLevel    String?
  caseType        String?
  reviewNotes     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  regionId        String?
  region          Region?          @relation(fields: [regionId], references: [id], onDelete: SetNull)
  media           Media[]

  @@index([type, status])
  @@index([createdAt])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  subject   String?
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
}

model Media {
  id           String    @id @default(cuid())
  type         MediaType
  url          String
  path         String?
  filename     String?
  mimeType     String?
  sizeBytes    Int?
  altText      String?
  caption      String?
  createdAt    DateTime  @default(now())

  uploadedById String?
  uploadedBy   User?      @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  postId       String?
  post         Post?      @relation(fields: [postId], references: [id], onDelete: Cascade)
  caseId       String?
  case         Case?      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  submissionId String?
  submission   Submission? @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([postId])
}

model SocialLink {
  id        String   @id @default(cuid())
  platform  String
  label     String
  url       String
  icon      String?
  isActive  Boolean  @default(true)
  showInHeader Boolean @default(false)
  showInFooter Boolean @default(true)
  showInContact Boolean @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entity, entityId])
  @@index([createdAt])
}

enum TelegramDraftStep {
  IDLE
  TITLE
  EXCERPT
  CONTENT
  AUTHOR
  COVER
  CATEGORY
  SCHEDULE
  CONFIRM
}

model TelegramDraft {
  id        String            @id @default(cuid())
  chatId    String            @unique
  userId    String?
  step      TelegramDraftStep @default(IDLE)
  data      Json              @default("{}")
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([chatId])
}

model TelegramPublishLog {
  id          String   @id @default(cuid())
  postId      String?
  chatId      String?
  channelId   String?
  messageId   String?
  status      String   @default("sent")
  error       String?
  createdAt   DateTime @default(now())

  @@index([postId])
  @@index([createdAt])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

